{
  "name": "antheon-backend",
  "version": "1.0.0",
  "description": "ANTHEON platform API — identity, RBAC, product modules, subscriptions, payments.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node -e \"import('./src/db.js').then(async ({pool})=>{const fs=await import('fs');await pool.query(fs.readFileSync('./db/schema.sql','utf8'));console.log('Migrated.');process.exit(0);})\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "stripe": "^16.9.0",
    "zod": "^3.23.8"
  }
}
